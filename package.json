{
  "name": "syncvcs-client",
  "version": "1.1.1",
  "description": "SyncVCS - Desktop Version Controller & File Sync System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "node scripts/run-electron-builder.js --win",
    "build:portable": "node scripts/run-electron-builder.js --win portable",
    "build:dir": "node scripts/run-electron-builder.js --win --dir"
  },
  "author": "SyncVCS",
  "license": "MIT",
  "build": {
    "appId": "com.syncvcs.client",
    "productName": "SyncVCS Client",
    "copyright": "Copyright © 2024 SyncVCS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "ui/**/*",
      "server/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "ui/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "ui/assets/icon.ico",
      "uninstallerIcon": "ui/assets/icon.ico",
      "installerHeaderIcon": "ui/assets/icon.ico",
      "shortcutName": "SyncVCS Client"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "chokidar": "^3.5.3",
    "diff": "^5.1.0",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
